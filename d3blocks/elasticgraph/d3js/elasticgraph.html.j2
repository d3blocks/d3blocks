<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    <style type="text/css">
        {% include "styles.css" %}
    </style>
    <script>
        {% include "d3.v2.js" %}
        {% include "d3graphscript.js" %}

        window.addEventListener('DOMContentLoaded', function () {
            d3graphscript({{ json_data }}, {
                width: {{ width }},
                height: {{ height }},
                dr: {{ point_radius }},
                off: {{ hull_offset }},
                debug: {{ debug }},
                single_click_expand: {{ single_click_expand|int }},
                collision: {{ collision }},
                charge: {{ charge }},
                sticky: {{ sticky|int }},
                label_zoom_threshold: {{ label_zoom_threshold }}
            })
        });
    </script>
</head>
<body></body>
</html>

